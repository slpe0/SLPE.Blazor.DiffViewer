<Project Sdk="Microsoft.NET.Sdk.Razor">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <PackageId>SLPE.Blazor.DiffViewer</PackageId>
    <Version>1.0.0</Version>
    <Authors>SLPE</Authors>
    <Description>A Blazor component for displaying HTML diff output with highlighted changes and clean view toggle.</Description>
    <PackageTags>blazor;diff;html-diff;diff-viewer</PackageTags>
    <RepositoryUrl>https://github.com/slpe0/SLPE.Blazor.DiffViewer</RepositoryUrl>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
  </PropertyGroup>
  <ItemGroup>
    <SupportedPlatform Include="browser" />
  </ItemGroup>
</Project>